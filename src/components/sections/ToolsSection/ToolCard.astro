---
import type { SvgComponent } from "astro/types";

interface Props {
  figcaption: string;
  // SVG imports are components in Astro; the last tools entry has no logos.
  logos?: (SvgComponent & ImageMetadata)[];
}

const { figcaption, logos } = Astro.props;
---

<li>
  {
    logos ? (
      <figure>
        {logos.map((Logo) => (
          <Logo />
        ))}
        <figcaption>{figcaption}</figcaption>
      </figure>
    ) : (
      <p>{figcaption}</p>
    )
  }
</li>

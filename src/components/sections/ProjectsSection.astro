---
import Section from "@components/UI/Section.astro";
import { Image } from "astro:assets";
import { type Locale, useTranslations } from "@i18n/ui";
import { getProjects, sanityImage } from "@lib/queries";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const projects = await getProjects(locale);
---

<Section id="projects" title={t("projects.title")} class="wrapper">
  <ul>
    {
      projects.map((project, index) => (
        <li>
          <button
            type="button"
            data-hover-direction
            aria-expanded="false"
            aria-controls={`project-${index}`}
            data-umami-event="project-open"
            data-umami-event-project={project.title}
          >
            <h3>{project.title}</h3>
            <div aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
            <div aria-hidden="true" />
          </button>

          <article id={`project-${index}`} hidden>
            <div data-project-img>
              <Image
                src={sanityImage(project.desktopImage.url, { w: 1200 })!}
                alt={`${project.title} desktop screenshot`}
                width={project.desktopImage.width}
                height={project.desktopImage.height}
                loading="lazy"
              />
              <Image
                src={sanityImage(project.mobileImage.url, { w: 600 })!}
                alt={`${project.title} mobile screenshot`}
                width={project.mobileImage.width}
                height={project.mobileImage.height}
                loading="lazy"
              />
            </div>

              <div data-project-info>
                <p>{project.description || t("projects.descriptionSoon")}</p>

                <div>
                  <div>
                    <h4>{t("projects.services")}</h4>
                    <ul>
                      {project.services?.map((service) => <li>{service}</li>)}
                    </ul>
                  </div>
                  <div>
                    <h4>{t("projects.technologies")}</h4>
                    <ul>
                      {project.tools?.map((tool) => <li>{tool}</li>)}
                    </ul>
                  </div>
                </div>
                {project.link ? (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener"
                    data-umami-event="project-visit"
                    data-umami-event-project={project.title}
                  >
                    {t("projects.visitWebsite")}
                  </a>
                ) : (
                  <span>{t("projects.linkUnavailable")}</span>
                )}
            </div>
          </article>
        </li>
      ))
    }
  </ul>
</Section>

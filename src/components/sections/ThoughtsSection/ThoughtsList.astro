---
import { Image } from "astro:assets";
import { type Locale, useTranslations } from "@i18n/ui";
import { getCleanRelativeLocaleUrl } from "@i18n/utils";
import { getThoughtCards } from "@lib/queries";
import { urlFor } from "@lib/image";

interface Props {
  headingLevel?: "h2" | "h3";
  showViewAll?: boolean;
  excludeId?: string;
  limit?: number;
  locale: Locale;
}

const {
  headingLevel = "h3",
  showViewAll = true,
  excludeId,
  limit = 3,
  locale,
} = Astro.props;

const t = useTranslations(locale);
const Heading = headingLevel;

const posts = await getThoughtCards(locale, { excludeEnSlug: excludeId, limit });
---

<ul>
  {
    posts.map((post) => {
      // Sanity does this crop, so the editor's hotspot is honoured here.
      const cardUrl = urlFor(post.mainImage)
        .width(600)
        .height(400)
        .fit("crop")
        .auto("format")
        .quality(80)
        .url();
      return (
        <li>
          <article>
            <a href={getCleanRelativeLocaleUrl(locale, `thoughts/${post.slug}`)}>
              <Heading>{post.title}</Heading>
            </a>
            <p>{post.description}</p>
            {cardUrl && (
              <Image
                src={cardUrl}
                alt={post.mainImage.alt ?? `${post.title} cover`}
                width={600}
                height={400}
                loading="lazy"
              />
            )}
          </article>
        </li>
      );
    })
  }
  {
    showViewAll && (
      <li data-element="view-all">
        <a href={getCleanRelativeLocaleUrl(locale, "thoughts")}>
          <Heading>
            <span>{t("thoughts.viewAll")}</span>
            <span aria-hidden="true">→</span>
          </Heading>
        </a>
      </li>
    )
  }
</ul>

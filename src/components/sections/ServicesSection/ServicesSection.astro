---
import ServiceCard from "@components/sections/ServicesSection/ServiceCard.astro";
import SocialLinksList from "@components/UI/SocialLinksList.astro";
import Section from "@components/UI/Section.astro";
import ServiceCodeIcon from "@images/service-code.svg";
import ServiceUpgradeIcon from "@images/service-upgrade.svg";
import ServiceDesignIcon from "@images/service-design.svg";
import { type Locale, useTranslations } from "@i18n/ui";

import servicesEn from "@content/services/en.json";
import servicesBg from "@content/services/bg.json";
import servicesEs from "@content/services/es.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const icons = [ServiceCodeIcon, ServiceUpgradeIcon, ServiceDesignIcon];
const servicesMap = { en: servicesEn, bg: servicesBg, es: servicesEs };
const cards = servicesMap[locale];
---

<Section id="services" title={t("services.title")} class="wrapper">
  <main>
    {cards.map((card, i) => {
      const Icon = icons[i];
      const index = String(i + 1).padStart(3, "0");
      const isLast = i === cards.length - 1;

      return (
        <ServiceCard index={index} title={card.title}>
          {card.paragraphs.map((p) => <p>{p}</p>)}
          {isLast && (
            <aside
              slot="aside"
              class="grid-wrapper__center-cell mt-6 flex max-w-prose flex-wrap items-center justify-between gap-x-6 indent-0"
            >
              <p>{t("services.collaborate")} <span class="heading-mono">→</span></p>
              <address><SocialLinksList /></address>
            </aside>
          )}
          <Icon slot="icon" />
        </ServiceCard>
      );
    })}
  </main>
</Section>

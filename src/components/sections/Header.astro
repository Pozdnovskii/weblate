---
import SocialLinksList from "@components/UI/SocialLinksList.astro";
import LanguageSwitcher from "@components/UI/LanguageSwitcher.astro";
import { type Locale, useTranslations } from "@i18n/ui";
import { getCleanRelativeLocaleUrl } from "@i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

let homeUrl = getCleanRelativeLocaleUrl(locale, "/");
// Absolute guarantee that homeUrl does not end in a slash before adding anchors
// (unless it's the root English path "/")
if (homeUrl !== "/" && homeUrl.endsWith("/")) {
  homeUrl = homeUrl.slice(0, -1);
}

const isHome = Astro.url.pathname === homeUrl || Astro.url.pathname === homeUrl + "/";

const navItems = [
  { label: t("nav.home"), href: homeUrl },
  { label: t("nav.services"), href: homeUrl === "/" ? "/#services" : `${homeUrl}#services` },
  { label: t("nav.tools"), href: homeUrl === "/" ? "/#tools" : `${homeUrl}#tools` },
  { label: t("nav.howTo"), href: homeUrl === "/" ? "/#how-to" : `${homeUrl}#how-to` },
  { label: t("nav.thoughts"), href: getCleanRelativeLocaleUrl(locale, "thoughts") },
];
---

<header
  id="header"
  class="wrapper"
  style="--fade-index: 3"
  data-fade-animation={isHome || undefined}
  transition:persist={`header-${locale}`}
>
  <div id="header-content">
    <div id="header-top">
      <p>
        <span>Ivan Pozdnovskii</span>
        <span>Website Developer</span>
      </p>
      <button
        data-umami-event="header-navigation-toggle"
        id="header-btn"
        aria-label={t("header.toggleMenu")}
        aria-controls="header-nav"
        aria-expanded="false"
      >
        <div id="burger-line-middle"></div>
      </button>
    </div>

    <nav inert id="header-nav" aria-label="Main navigation">
      <div id="nav-content">
        <div>
          <ul id="menu-list">
            {
              navItems.map((item, index) => (
                <li>
                  <a
                    data-umami-event="header-navigation"
                    data-umami-event-link={item.label
                      .toLowerCase()
                      .replace(/\s+/g, "-")}
                    href={item.href}
                  >
                    <span aria-hidden="true">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <LanguageSwitcher locale={locale} />
        </div>

        <address>
          <SocialLinksList variant="vertical" />
        </address>
      </div>
    </nav>
  </div>
</header>

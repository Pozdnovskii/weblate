---
import type { GetStaticPaths } from "astro";
import { Image } from "astro:assets";
import { getAbsoluteLocaleUrl } from "astro:i18n";
import Layout from "@layouts/Layout.astro";
import ThoughtsList from "@components/sections/ThoughtsSection/ThoughtsList.astro";
import ThoughtBody from "@components/sections/ThoughtsSection/ThoughtBody.astro";
import SectionHeading from "@components/UI/SectionHeading.astro";
import { useTranslations, defaultLang, type Locale } from "@i18n/ui";
import { getThought, getThoughtPaths } from "@lib/queries";
import { urlFor } from "@lib/image";

export const getStaticPaths = (async () => {
  const locales: Locale[] = ["en", "bg", "es"];
  const paths = await getThoughtPaths();

  return locales.flatMap((locale) =>
    paths.map((p) => {
      const localeSlug = p.slugs[locale] ?? p.enSlug;
      return {
        params: {
          locale: locale === defaultLang ? undefined : locale,
          slug: localeSlug,
        },
        props: { enSlug: p.enSlug, locale, slugs: p.slugs },
      };
    }),
  );
}) satisfies GetStaticPaths;

const { enSlug, locale, slugs } = Astro.props as {
  enSlug: string;
  locale: Locale;
  slugs: Partial<Record<Locale, string>>;
};

const t = useTranslations(locale);
const post = await getThought(locale, enSlug);

if (!post) {
  return Astro.redirect("/404");
}

// Only resized here — the <Image> below asks for 1600x900, so Sharp does the
// actual crop (centred, hotspot-blind).
const heroUrl = urlFor(post.mainImage)
  .width(1600)
  .auto("format")
  .quality(80)
  .url();

// Cropped by Sanity and used as a plain URL, so the hotspot applies.
const ogUrl = urlFor(post.mainImage)
  .width(1200)
  .height(630)
  .fit("crop")
  .auto("format")
  .quality(80)
  .url();
const pageUrl = getAbsoluteLocaleUrl(locale, `thoughts/${post.slug}`);

const dateModified = post.updatedAt
  ? post.updatedAt.slice(0, 10)
  : post.date;

const articleNode = {
  "@type": "Article",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified,
  inLanguage: locale,
  url: pageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  image: ogUrl ?? undefined,
  author: {
    "@type": "Person",
    name: "Ivan Pozdnovskii",
    url: "https://weblateweb.dev",
  },
  publisher: {
    "@type": "Person",
    name: "Ivan Pozdnovskii",
    url: "https://weblateweb.dev",
  },
};

const faqNode =
  post.faq && post.faq.length
    ? {
        "@type": "FAQPage",
        mainEntity: post.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      }
    : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": faqNode ? [articleNode, faqNode] : [articleNode],
};

const alternateUrls = Object.fromEntries(
  (["en", "bg", "es"] as Locale[])
    .filter((l) => slugs[l])
    .map((l) => [l, getAbsoluteLocaleUrl(l, `thoughts/${slugs[l]}`)]),
);
---

<Layout
  title={`${post.metaTitle ?? post.title} | Ivan Pozdnovskii`}
  description={post.metaDescription ?? post.description}
  schema={articleSchema}
  ogImage={ogUrl ?? undefined}
  alternateUrls={alternateUrls}
>
  <main id="main" class="wrapper">
    <h1
      class="mb-[1em] max-w-[20em] text-[clamp(1.6875rem,1.26rem+2.13svw,2.625rem)] sm:mx-auto sm:text-center"
    >
      {post.title}
    </h1>
    <article class="prose mx-auto">
      {heroUrl && (
        <Image
          class="mb-16 rounded-lg"
          src={heroUrl}
          alt={post.mainImage.alt ?? `${post.title} cover`}
          width={1600}
          height={900}
          loading="eager"
        />
      )}
      {post.body && <ThoughtBody body={post.body} />}

      {post.faq && post.faq.length > 0 && (
        <section class="thought-faq">
          <h2>FAQ</h2>
          <dl>
            {post.faq.map((item) => (
              <div>
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}
    </article>

    <aside id="thoughts">
      <SectionHeading title={t("thoughts.recentTitle")} id="aside-title" />
      <ThoughtsList excludeId={enSlug} locale={locale} />
    </aside>
  </main>
</Layout>
